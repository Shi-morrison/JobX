# Anthropic
ANTHROPIC_API_KEY=

# SerpAPI
SERPAPI_KEY=

# Gmail OAuth (token.json is written at runtime by the OAuth flow)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# LinkedIn (used by Playwright session — never stored beyond .env)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Job search preferences
TARGET_ROLES=Software Engineer,Backend Engineer,Full Stack Engineer
TARGET_LOCATIONS=Remote,San Francisco,New York
MIN_FIT_SCORE=6
TARGET_COMP_MIN=150000
