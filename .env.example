# Anthropic
ANTHROPIC_API_KEY=

# SerpAPI
SERPAPI_KEY=

# Gmail OAuth (token.json is written automatically by the Gmail OAuth flow at runtime)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# LinkedIn (used by Playwright session — never stored beyond .env)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Job search preferences — list values must be JSON arrays
TARGET_ROLES=["Software Engineer","Backend Engineer","Full Stack Engineer"]
TARGET_LOCATIONS=["Remote","San Francisco","New York"]
MIN_FIT_SCORE=6
TARGET_COMP_MIN=150000
